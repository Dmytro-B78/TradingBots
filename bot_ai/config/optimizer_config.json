{
  "optimizer": {
    "symbol": "BTCUSDT",
    "interval": "5m",
    "start_date": "2024-01-01",
    "end_date": "2024-12-31",
    "initial_balance": 10000,
    "strategy": {
      "name": "meta_strategy",
      "params": {
        "mode": "majority",
        "position_size": 0.01,
        "strategies": [
          {
            "name": "ma_crossover_strategy",
            "params": {
              "short_window": [5, 9, 14],
              "long_window": [20, 30, 50],
              "position_size": 0.01
            }
          },
          {
            "name": "rsi_strategy",
            "params": {
              "period": [10, 14, 20],
              "oversold": [25, 30, 35],
              "overbought": [65, 70, 75],
              "position_size": 0.01
            }
          },
          {
            "name": "macd_strategy",
            "params": {
              "fast_period": [8, 12, 16],
              "slow_period": [20, 26, 32],
              "signal_period": [7, 9, 11],
              "position_size": 0.01
            }
          },
          {
            "name": "bollinger_strategy",
            "params": {
              "period": [14, 20, 30],
              "multiplier": [1.5, 2, 2.5],
              "position_size": 0.01
            }
          }
        ]
      }
    }
  }
}
