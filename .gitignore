﻿# ============================================
# File: .gitignore
# Назначение: Исключение чувствительных и временных файлов из Git
# ============================================

# 🔐 Конфигурация и ключи
.env

# 🧪 Примеры и шаблоны
!.env.example

# 🗃 Кэш и временные файлы
__pycache__/
*.pyc
*.pyo
*.pyd

# 🧪 Логи и отладка
*.log

# 📦 Виртуальные окружения
.venv/
env/
venv/

# 🧱 IDE и редакторы
.vscode/
.idea/
*.swp
